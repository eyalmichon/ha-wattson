#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

HA_CONFIG="${PWD}/.dev/ha"

# Ensure HA config exists (check for .HA_VERSION, not just the directory).
if [[ ! -f "${HA_CONFIG}/.HA_VERSION" ]]; then
    mkdir -p "${HA_CONFIG}"
    echo "Creating initial Home Assistant config..."
    hass --config "${HA_CONFIG}" --script ensure_config
fi

# Create custom_components dir and symlink our integrations.
mkdir -p "${HA_CONFIG}/custom_components"
if [[ ! -e "${HA_CONFIG}/custom_components/wattson" ]]; then
    ln -sf "${PWD}/custom_components/wattson" "${HA_CONFIG}/custom_components/wattson"
fi
if [[ ! -e "${HA_CONFIG}/custom_components/wattson_simulator" ]]; then
    ln -sf "${PWD}/tests/wattson_simulator" "${HA_CONFIG}/custom_components/wattson_simulator"
fi

# Create default dev user and skip onboarding wizard on first run.
if [[ ! -f "${HA_CONFIG}/.storage/onboarding" ]]; then
    echo "Creating default dev user (admin / admin)..."
    hass --script auth -c "${HA_CONFIG}" add admin admin

    mkdir -p "${HA_CONFIG}/.storage"

    cat > "${HA_CONFIG}/.storage/onboarding" << 'ONBOARDING'
{
    "version": 4,
    "minor_version": 1,
    "key": "onboarding",
    "data": {
        "done": ["user", "core_config", "analytics", "integration"]
    }
}
ONBOARDING

    cat > "${HA_CONFIG}/.storage/auth" << 'AUTH'
{
    "version": 1,
    "minor_version": 1,
    "key": "auth",
    "data": {
        "users": [
            {
                "id": "dev-owner-id",
                "group_ids": ["system-admin"],
                "is_owner": true,
                "is_active": true,
                "name": "admin",
                "system_generated": false,
                "local_only": false
            }
        ],
        "groups": [],
        "credentials": [
            {
                "id": "dev-credential-id",
                "user_id": "dev-owner-id",
                "auth_provider_type": "homeassistant",
                "auth_provider_id": null,
                "data": {
                    "username": "admin"
                }
            }
        ],
        "refresh_tokens": []
    }
}
AUTH

    echo "Dev user created. Login with admin / admin"
fi

# Write a minimal dev configuration (avoids default_config and its heavy deps).
if ! grep -q "custom_components.wattson" "${HA_CONFIG}/configuration.yaml" 2>/dev/null; then
    cat > "${HA_CONFIG}/configuration.yaml" << 'YAML'
homeassistant:
  name: Dev
  unit_system: metric

frontend:
http:
config:
system_log:
recorder:
history:
logbook:
sun:
webhook:
person:
zone:
tag:
backup:
homeassistant_alerts:
my:
automation:
script:
scene:
group:
input_boolean:
input_number:
input_text:
input_select:
input_datetime:
input_button:
template:
timer:
counter:
schedule:

logger:
  default: warning
  logs:
    custom_components.wattson: debug
YAML
fi

echo "Starting Home Assistant..."
echo "Access at: http://localhost:8123"
echo "Login:     admin / admin"
echo ""

if [[ "${DEBUG}" == "1" || "${1}" == "--debug" ]]; then
    echo "Debug mode enabled."
    hass --config "${HA_CONFIG}" --debug
else
    hass --config "${HA_CONFIG}"
fi
